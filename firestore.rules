rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Document ID: userId (matches auth.uid)
    // Fields:
    //   - uid: string (required)
    //   - name: string (required)
    //   - username: string (required, lowercase)
    //   - role: string (required, 'admin', 'agent', 'client')
    //   - agentLocation?: string ('china' | 'madagascar', optional for agents)
    //   - createdAt: string (required)
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    function isBootstrapAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == 'gianno@system.local' || 
        request.auth.token.email == 'admin@k7.com' ||
        request.auth.token.email == 'admin2@k7.com' ||
        request.auth.token.email == 'gianno@k7.com' ||
        request.auth.token.email == 'alexander.razalgoul@gmail.com'
      );
    }
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'username', 'role', 'createdAt']) &&
             data.keys().hasOnly(['uid', 'name', 'username', 'role', 'createdAt', 'clientId', 'agentLocation', 'isDeleted', 'updatedAt']) &&
             data.uid is string && data.uid.size() > 0 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.username is string && data.username.size() > 0 && data.username.size() < 100 &&
             data.role in ['admin', 'agent', 'client'] &&
             data.createdAt is string &&
             (!('clientId' in data) || (data.clientId is string && data.clientId.size() > 0)) &&
             (!('agentLocation' in data) || data.agentLocation in ['china', 'madagascar']) &&
             (!('isDeleted' in data) || data.isDeleted is bool) &&
             (!('updatedAt' in data) || data.updatedAt is string);
    }

    function isAgent() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'agent';
    }

    function isClient() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'client';
    }
    
    function isValidParcel(data) {
      return data.keys().hasAll(['id', 'trackingNumber', 'status', 'createdAt', 'updatedAt']) &&
             data.id is string && data.id.size() > 0 &&
             data.trackingNumber is string && data.trackingNumber.size() > 0 && data.trackingNumber.size() < 100 &&
             data.status in ['Entrant', 'En attente', 'Expédié', 'Prêt', 'Livré', 'En Transit'] &&
             (!('linked' in data) || data.linked is bool) &&
             (!('location' in data) || data.location in ['china', 'madagascar']) &&
             data.createdAt is string &&
             data.updatedAt is string;
    }

    function isValidLog(data) {
      return data.keys().hasAll(['id', 'parcelId', 'userId', 'action', 'timestamp']) &&
             data.id is string && data.id.size() > 0 &&
             data.parcelId is string && data.parcelId.size() > 0 &&
             data.userId is string && data.userId.size() > 0 &&
             data.action is string && data.action.size() > 0 && data.action.size() < 100 &&
             data.timestamp is string;
    }

    function isValidSack(data) {
      return data.keys().hasAll(['id', 'barcode', 'status', 'createdAt', 'updatedAt', 'createdBy']) &&
             data.id is string && data.id.size() > 0 &&
             data.barcode is string && data.barcode.size() > 0 &&
             data.status in ['Ouvert', 'Fermé', 'Reçu', 'En Transit'] &&
             (!('location' in data) || data.location in ['china', 'madagascar']) &&
             data.createdAt is string &&
             data.updatedAt is string &&
             data.createdBy is string && data.createdBy.size() > 0;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin() || isAgent();
      // FIX: Allow bootstrap admins to create their own accounts without needing existing user doc
      allow create: if isValidUser(request.resource.data) && request.resource.data.uid == userId && 
                       (isBootstrapAdmin() || isAdmin());
      allow update: if isAdmin() && isValidUser(request.resource.data) && request.resource.data.uid == resource.data.uid;
      allow delete: if isAdmin();
    }

    match /parcels/{parcelId} {
      // READ: Admin/Agent can read all parcels. Clients can only read their own parcels.
      allow read: if isAdmin() || isAgent() || (isClient() && request.auth.uid == resource.data.clientId);
      
      // CREATE: Only authenticated users can create parcels (agents, admins, clients)
      allow create: if isAuthenticated() && isValidParcel(request.resource.data) && request.resource.data.id == parcelId;
      
      // UPDATE: Authenticated users can update parcels. Clients cannot modify parcels not assigned to them.
      allow update: if isAuthenticated() && isValidParcel(request.resource.data) && request.resource.data.id == resource.data.id &&
                       (isAdmin() || isAgent() || (isClient() && request.auth.uid == resource.data.clientId));
      
      // DELETE: Only admin can delete
      allow delete: if isAdmin();
    }

    match /logs/{logId} {
      // READ: Authenticated users can read logs. Clients can only see logs for their own parcels.
      allow read: if isAuthenticated() && (isAdmin() || isAgent() || 
                       (isClient() && exists(/databases/$(database)/documents/parcels/$(resource.data.parcelId)) && 
                        get(/databases/$(database)/documents/parcels/$(resource.data.parcelId)).data.clientId == request.auth.uid));
      
      // CREATE: Authenticated users can create logs
      allow create: if isAuthenticated() && isValidLog(request.resource.data) && request.resource.data.id == logId;
      
      // UPDATE: Logs are immutable
      allow update: if false;
      
      // DELETE: Only admin can delete
      allow delete: if isAdmin();
    }

    match /sacks/{sackId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidSack(request.resource.data) && request.resource.data.id == sackId;
      allow update: if isAuthenticated() && isValidSack(request.resource.data) && request.resource.data.id == resource.data.id &&
                       // Workflow: Ouvert ↔ Fermé → En Transit → Reçu (forward-only after transit)
                       (resource.data.status in ['Ouvert', 'Fermé'] ||
                        (resource.data.status == 'En Transit' && request.resource.data.status == 'Reçu'));
      allow delete: if isAdmin();
    }

    match /settings/{documentId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
